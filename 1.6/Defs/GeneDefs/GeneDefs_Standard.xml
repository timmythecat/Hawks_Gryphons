<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <GeneDef Name="GeneGryphonSkinColor" ParentName="GeneSkinColorOverride" MayRequire="Ludeon.RimWorld.Biotech" Abstract="True">
        <displayCategory>Gryhpon</displayCategory>
        <randomBrightnessFactor>0.1</randomBrightnessFactor>
    </GeneDef>

    <GeneDef ParentName="GeneGryphonSkinColor" MayRequire="Ludeon.RimWorld.Biotech">
        <defName>Gryphon_Skin</defName>
        <label>gryphon skin</label>
        <description>Just a copy of Sheer white skin, but made a replacement just for gryphons to display properly</description>
        <skinColorOverride>(250, 240, 240)</skinColorOverride>
        <displayOrderInCategory>1</displayOrderInCategory>
    </GeneDef>

    <GeneDef ParentName="GeneGryphonSkinColor" MayRequire="Ludeon.RimWorld.Biotech">
        <defName>Gryphon_Skin_Dark</defName>
        <label>gryphon skin dark</label>
        <description>Just a copy of Sheer Grey skin, but made a replacement just for gryphons to display properly</description>
        <skinColorOverride>(140, 135, 135)</skinColorOverride>
        <displayOrderInCategory>2</displayOrderInCategory>
    </GeneDef>

    <GeneDef ParentName="GeneGryphonSkinColor" MayRequire="Ludeon.RimWorld.Biotech">
        <defName>Gryphon_Skin_brown</defName>
        <label>gryphon skin brown</label>
        <description>A gene for making gryphon fur brown</description>
        <skinColorOverride>(176, 156, 145)</skinColorOverride>
        <displayOrderInCategory>3</displayOrderInCategory>
    </GeneDef>

    <GeneDef ParentName="GeneGryphonSkinColor" MayRequire="Ludeon.RimWorld.Biotech">
        <defName>Gryphon_Skin_darkbrown</defName>
        <label>gryphon skin dark brown</label>
        <description>A gene for making gryphon fur brown</description>
        <skinColorOverride>(122, 102, 89)</skinColorOverride>
        <displayOrderInCategory>4</displayOrderInCategory>
    </GeneDef>

    <GeneDef ParentName="GeneGryphonSkinColor" MayRequire="Ludeon.RimWorld.Biotech">
        <defName>Gryphon_Skin_green</defName>
        <label>gryphon skin dark brown</label>
        <description>A gene for making gryphon fur green</description>
        <skinColorOverride>(174, 210, 173)</skinColorOverride>
        <displayOrderInCategory>4</displayOrderInCategory>
    </GeneDef>

    <GeneDef MayRequire="Ludeon.RimWorld.Biotech">
        <defName>Hawk_FireSpew</defName>
        <label>gryph fire spew</label>
        <description>Gryphons with this gene are able to produse and breathe a flammable liquid. The liquid sticks to anything in a small area and can ignite people, objects, and the ground.</description>
        <iconPath>UI/Icons/Genes/Gene_Firespew</iconPath>
        <displayCategory>Gryhpon</displayCategory>
        <abilities>
            <li>Hawk_FireSpew</li>
        </abilities>
        <descriptionHyperlinks>
            <AbilityDef>Hawk_FireSpew</AbilityDef>
        </descriptionHyperlinks>
        <biostatMet>-1</biostatMet>
        <symbolPack>
            <wholeNameSymbols>
                <li><symbol>burner</symbol></li>
                <li><symbol>igniter</symbol></li>
            </wholeNameSymbols>
            <prefixSymbols>
                <li><symbol>fire</symbol></li>
                <li><symbol>flame</symbol></li>
                <li><symbol>pyre</symbol></li>
                <li><symbol>pyro</symbol></li>
                <li><symbol>spark</symbol></li>
                <li><symbol>ember</symbol></li>
                <li><symbol>spew</symbol></li>
                <li><symbol>burn</symbol></li>
            </prefixSymbols>
            <suffixSymbols>
                <li><symbol>light</symbol></li>
                <li><symbol>burner</symbol></li>
                <li><symbol>pyro</symbol></li>
                <li><symbol>ash</symbol></li>
            </suffixSymbols>
        </symbolPack>
    </GeneDef>
</Defs>