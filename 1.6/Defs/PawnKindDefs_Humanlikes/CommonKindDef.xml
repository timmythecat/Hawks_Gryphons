<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <PawnKindDef ParentName="BasePlayerPawnKind">
        <defName>Hawk_Gryphon_Colonist</defName>
        <label>colonist</label>
        <race>Hawk_common_gryphon</race>
        <defaultFactionType>PlayerColony</defaultFactionType>

        <!-- This is a required field. 13~21 is the default value for Crashlanded player colonists. -->
        <initialResistanceRange>13~21</initialResistanceRange>
    </PawnKindDef>
 
    <PawnKindDef ParentName="SpaceRefugeeBase">
        <defName>Hawk_Gryphon_SpaceRefugee</defName>
        <label>space refugee</label>
        <race>Hawk_common_gryphon</race>
        <combatPower>90</combatPower>
        <chemicalAddictionChance>0.05</chemicalAddictionChance>
        <apparelMoney>0~1000</apparelMoney>
        <apparelIgnoreSeasons>true</apparelIgnoreSeasons>
        <initialWillRange>1~3</initialWillRange>
        <initialResistanceRange>14~22</initialResistanceRange>
    </PawnKindDef>
</Defs>