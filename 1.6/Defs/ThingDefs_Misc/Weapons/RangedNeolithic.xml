<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BaseWeaponNeolithic" Name="Bow_Gryph">
    <defName>Gryph_Crossbow</defName>
    <label>gryphon crossbow</label>
    <description>A big and powerful crossbow. Fires a large arrow long distances.</description>
    <graphicData>
      <texPath>Things/Crossbow</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.3</drawSize>
    </graphicData>
    <soundInteract>Bow_Large</soundInteract>
    <costList>
      <WoodLog>60</WoodLog>
      <Steel>30</Steel>
    </costList>
    <thingSetMakerTags>
      <li>RewardStandardQualitySuper</li>
    </thingSetMakerTags>
    <statBases>
      <WorkToMake>12000</WorkToMake>
      <Mass>12.0</Mass>
      <AccuracyTouch>0.6</AccuracyTouch>
      <AccuracyShort>0.85</AccuracyShort>
      <AccuracyMedium>0.75</AccuracyMedium>
      <AccuracyLong>0.50</AccuracyLong>
      <RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>GryphonNeolithic</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Arrow_Gryph</defaultProjectile>
        <warmupTime>0.8</warmupTime>
        <range>35.9</range>
        <soundCast>Bow_Large</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>limb</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>20</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <recipeMaker>
      <recipeUsers>
        <li>CraftingSpot</li>
      </recipeUsers>
      <researchPrerequisite>PrimitiveGryphonWeapons</researchPrerequisite>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>530</displayPriority>
    </recipeMaker>
    <rotateInShelves>false</rotateInShelves>
  </ThingDef>

  <ThingDef ParentName="BaseProjectileNeolithic">
    <defName>Arrow_Gryph</defName>
    <label>gryph crossbow arrow</label>
    <graphicData>
      <texPath>Things/Gryph_Arrow</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.2</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Arrow</damageDef>
      <damageAmountBase>20</damageAmountBase>
      <speed>50</speed>
    </projectile>
  </ThingDef>

